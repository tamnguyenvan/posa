<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/cameraContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/black"
        app:layout_constraintBottom_toTopOf="@id/hudStrip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            app:implementationMode="performance"
            app:scaleType="fillCenter" />

        <ImageView
            android:id="@+id/videoPreviewImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            android:contentDescription="@string/video_preview"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <com.example.safetypose.OverlayView
            android:id="@+id/overlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/permissionPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/permissionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/camera_permission_title"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/permissionMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="@string/camera_permission_message"
                android:textColor="@color/hud_secondary"
                android:textSize="15sp" />

            <Button
                android:id="@+id/requestPermissionButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="22dp"
                android:minWidth="156dp"
                android:text="@string/grant_camera"
                android:textAllCaps="false"
                android:textStyle="bold" />

            <Button
                android:id="@+id/permissionPickVideoButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#CC111111"
                android:minWidth="156dp"
                android:text="@string/choose_video_instead"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/pickVideoButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="top|start"
            android:layout_margin="16dp"
            android:backgroundTint="#CC111111"
            android:minWidth="72dp"
            android:text="@string/pick_video"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/videoStatusText"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="22dp"
            android:background="#99000000"
            android:gravity="center"
            android:minWidth="128dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="Video 42%"
            tools:visibility="visible" />

        <Button
            android:id="@+id/switchCameraButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:backgroundTint="#CC111111"
            android:minWidth="72dp"
            android:text="@string/switch_camera"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/hudStrip"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@color/hud_background"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/fpsText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/hud_fps_empty"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/spineText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/hud_spine_empty"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/safetyText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/hud_safety_empty"
            android:textColor="@color/safety_green"
            android:textSize="16sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
